
<%- include('layouts/header') %>

<%- include('layouts/nav') %>

    <section class="bg-light py-5">
        <div class="container-xl">
            <div class="text-center mb-5">
                <h2 class="fw-bolder">Please add product here</h2>
            </div>
            <div class="row p-3 bg-light justify-content-center">
                <div class="col-lg-7 col-12">
                    <form action="/create/product" class="p-4 border rounded-3 bg-light" method="post"
                        enctype="multipart/form-data">
                        <!-- Name input-->
                        <div class="form-floating mb-3">
                            <input class="form-control form-control-lg" name="name" type="text"
                                placeholder="Enter your product name" required>
                            <label for="name">Product Name</label>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control form-control-lg" name="slug" type="text" placeholder="Enter Product Slug"
                                required>
                            <label for="slug">Product Slug</label>
                        </div>
                        <div class="my-3">
                            <label for="category" class="form-label fs-5">Category</label>
                            <select class="form-select field-control" name="category" required>
                                <% categories.forEach(cat=> { %>
                                    <option value="<%= cat._id %>">
                                        <%= cat.categoryName %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <!-- Email address input-->
                        <div class="form-floating mb-3">
                            <input class="form-control form-control-lg" name="description" type="text"
                                placeholder="Enter Product Description" required>
                            <label for="description">Product Description</label>
                        </div>
                        <!-- Message input-->
                        <div class="mb-3">
                            <input type="file" class="form-control form-control-lg" name="image"
                                placeholder="Choose Image File">
                        </div>
                        <!-- Submit Button-->
                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg" type="submit">Create Product</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>