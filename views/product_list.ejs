
<%- include('layouts/header') %>

<h1>Product List</h1>

<body>
    <div class="container-xl">
        <div class="row mt-5">
            <div class="col-4 mb-0 border-bottom border-primary">
                <h2 class="lead fw-normal fs-3 text-capitalize">List of students:</h2>
            </div>
            <div class="col-5 mb-0 border-bottom border-primary">
                <h4 class="lead fw-bold fs-3 text-capitalize">number of students: <%= data.length %>
                </h4>
            </div>
            <div class="col-3 mb-0 border-bottom border-primary">
                <div class="text-end">
                    <a href="/add/product" class="btn btn-lg btn-primary w-100 mb-3">Create Product<i
                            class="fa-solid fa-plus mx-lg-2 mx-1"></i></a>
                </div>
            </div>

            <div class="table-responsive px-0">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th class="text-capitalize text-center fs-6" scope="col">Serial No.</th>
                            <th class="text-capitalize text-center fs-6" scope="col">Id</th>
                            <th class="text-capitalize text-center fs-6" scope="col">Product Name</th>
                            <th class="text-capitalize text-center fs-6" scope="col">Product Category</th>
                            <th class="text-capitalize text-center fs-6" scope="col">Product Description</th>
                            <th class="text-capitalize text-center fs-6" scope="col">Product Slug</th>
                        </tr>
                    </thead>
                    <% if (data.length===0) { %>

                        <tr>
                            <td class="fs-5 text-capitalize fw-normal text-center" colspan="14">No Records Found</td>
                        </tr>

                        <% } else { %>

                            <% data.forEach((product, index)=> { %>

                    <tbody class="table-group-divider">
                        <tr>
                            <td class="fs-5 text-capitalize fw-normal text-center" scope="row">
                                <%= index + 1 %>
                            </td>
                            <td class="fs-5 text-capitalize fw-normal text-center">
                                <%= product._id.toString().slice(20, 24) %>
                            </td>
                            <td class="fs-5 text-capitalize fw-normal text-center">
                                <%= product.name %>
                            </td>
                            <td class="fs-5 text-capitalize fw-normal text-center">
                                <%= product.category?.categoryName || "No Category" %>
                            </td>
                            <td class="fs-5 text-capitalize fw-normal text-center">
                                <%= product.description %>
                            </td>
                            <td class="fs-5 text-capitalize fw-normal text-center">
                                <%= product.slug %>
                            </td>

                            <!-- <td>
                                <a href="/product/edit/<%=product._id%>"
                                    class="btn btn-lg btn-warning w-100">Edit Product<i
                                        class="fa-regular fa-pen-to-square mx-lg-2 mx-1"></i>
                                </a>
                            </td>
                            <td>
                                <a href="/product/softdelete/<%=product._id%>"
                                    class="btn btn-lg btn-danger w-100">Delete Product<i
                                        class="fa-regular fa-trash-can mx-lg-2 mx-1"></i>
                                </a>
                            </td> -->
                        </tr>
                        <% })%>
                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>